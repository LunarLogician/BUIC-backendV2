# ───── Firebase Configuration ─────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# Or use Application Default Credentials on cloud environment

# ───── Server ─────
PORT=3000
NODE_ENV=production

# ───── Lemonsqueezy Webhook ─────
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_from_lemonsqueezy_dashboard
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key

# Product IDs
LEMONSQUEEZY_BASIC_PRODUCT_ID=1487575
LEMONSQUEEZY_PRO_PRODUCT_ID=1487490

# ───── Email Configuration (Choose One) ─────

# Option 1: SMTP (Gmail, Outlook, custom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@buassistant.com

# Option 2: SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ───── Download Links ─────
# Where APK files are hosted for download
APK_DOWNLOAD_URL_BASIC=https://downloads.example.com/BU_Assistant_v1.1.0_BASIC.apk
APK_DOWNLOAD_URL_PRO=https://downloads.example.com/BU_Assistant_v1.1.0_PRO.apk

# ───── Frontend URLs ─────
APP_URL=https://buassistant.com
SUBSCRIPTION_MANAGEMENT_URL=https://buassistant.com/account/subscriptions

# ───── JWT Security ─────
JWT_SECRET=your_super_secret_jwt_key_for_token_generation

# ───── Admin Credentials ─────
# Used for manual approval endpoints
ADMIN_SECRET=your_admin_secret_key
